{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/_/backend/(.*)",
            "destination": "/_/backend/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}